# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================
# Copy this file to .env and fill in your values for local development.

# Database (Local - SQLite file)
DATABASE_URL="file:./dev.db"

# Google Gemini API — get key from https://aistudio.google.com
GEMINI_API_KEY="your-gemini-api-key"

# Catalog API
CATALOG_API_URL="https://api.studioxlowes.com/catalog/v3"

# App URL (used for export links etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# VERCEL / PRODUCTION
# =============================================================================
# .env is NOT deployed to Vercel. Add these in:
# Vercel Dashboard → Your Project → Settings → Environment Variables
#
# Required for production:
#   - TURSO_DATABASE_URL    (from: turso db show <db-name>)
#   - TURSO_AUTH_TOKEN      (from: turso db tokens create <db-name>)
#   - GEMINI_API_KEY
#   - NEXT_PUBLIC_APP_URL   (e.g. https://alder-studio.vercel.app)
#
# Optional:
#   - CATALOG_API_URL       (defaults to studioxlowes if unset)
#   - UPLOAD_DIR            (for persistent uploads; Vercel has ephemeral fs)
# =============================================================================

# Database (Production - Turso)
# TURSO_DATABASE_URL="libsql://your-db-xxx.turso.io"
# TURSO_AUTH_TOKEN="your-auth-token"

# File Storage (Production - e.g. Render Disk)
# UPLOAD_DIR="/data/uploads"
